# Local secrets file for Terraform — DO NOT COMMIT real values.
#
# Copy this file to local.auto.tfvars and replace each placeholder with your
# actual value.  Terraform automatically loads all *.auto.tfvars files, so no
# extra flags are needed.
#
#   cp infra/local.auto.tfvars.example infra/local.auto.tfvars
#
# In CI, these variables are supplied via TF_VAR_* environment variables from
# GitHub Secrets instead of this file.

# SQL Server administrator credentials
sql_admin_login    = "REPLACE_WITH_SQL_ADMIN_LOGIN"
sql_admin_password = "REPLACE_WITH_SQL_ADMIN_PASSWORD"
