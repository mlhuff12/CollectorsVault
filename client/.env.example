# Copy this file to .env.local and fill in values for your environment.
# For production, set VITE_API_BASE_URL as an environment variable in
# your build pipeline (e.g. GitHub Actions secret / Netlify / Vercel env var).
# REACT_APP_API_BASE_URL is retained for CRA compatibility during migration.

# npm start now runs Vite on https://localhost:3000 by default.
# Keep HTTPS=true only if you still run legacy CRA scripts locally.
HTTPS=true
VITE_API_BASE_URL=https://your-api-hostname.example.com
REACT_APP_API_BASE_URL=https://your-api-hostname.example.com
