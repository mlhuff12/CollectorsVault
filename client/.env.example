# Copy this file to .env.local and fill in values for your environment.
# For production, set REACT_APP_API_BASE_URL as an environment variable in
# your build pipeline (e.g. GitHub Actions secret / Netlify / Vercel env var).

# HTTPS=true enables the React dev server to serve over HTTPS, which is required
# for camera access (barcode scanner) to work on mobile devices.
HTTPS=true
REACT_APP_API_BASE_URL=https://your-api-hostname.example.com
