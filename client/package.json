{
  "name": "collectors-vault-client",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "dev:vite": "vite",
    "build:vite": "npm run build",
    "preview:vite": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ci:vite": "npm run test:ci",
    "test:ui": "vitest run src/tests/ui --passWithNoTests",
    "test:unit": "vitest run src/tests/unit --passWithNoTests",
    "test:integration": "vitest run src/tests/integration --passWithNoTests",
    "test:all": "npm run test:ui && npm run test:unit && npm run test:integration",
    "verify:vite": "npm run build:vite && npm run test:ci:vite"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "html5-qrcode": "^2.3.8",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "typescript": "^4.1.2"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "vite": "^7.1.6",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0",
    "@types/jest": "^27.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
