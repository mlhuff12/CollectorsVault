{
  "name": "collectors-vault-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "dev:vite": "vite",
    "build:vite": "npm run build",
    "preview:vite": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ci:vite": "npm run test:ci",
    "test:ui": "vitest run src/tests/ui --passWithNoTests",
    "test:unit": "vitest run src/tests/unit --passWithNoTests",
    "test:integration": "vitest run src/tests/integration --passWithNoTests",
    "test:all": "npm run test:ui && npm run test:unit && npm run test:integration",
    "lint": "eslint src",
    "verify:vite": "npm run build:vite && npm run test:ci:vite"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@types/qrcode": "^1.5.6",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.13.6",
    "html5-qrcode": "^2.3.8",
    "mdi-material-ui": "^7.9.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "typescript": "^4.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^27.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.0.3",
    "jsdom": "^26.1.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
