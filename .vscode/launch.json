{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: Launch .NET",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}/server\" && dotnet run --launch-profile https --urls https://0.0.0.0:5000 --project \"${workspaceFolder}/server/CollectorsVault.Api.csproj\"",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      }
    },
    {
      "name": "API: Debug .NET (C#)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/server/CollectorsVault.Api.csproj"
    },
    {
      "name": "Client: Start Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}/client\" && FAST_REFRESH=false NODE_OPTIONS=--openssl-legacy-provider HOST=0.0.0.0 npm start"
    },
    {
      "name": "Client: Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "https://localhost:3000",
      "webRoot": "${workspaceFolder}/client/src"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: API + Client",
      "configurations": [
        "API: Debug .NET (C#)",
        "Client: Start Dev Server"
      ]
    }
  ]
}