{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "API: Run .NET",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--urls",
        "http://0.0.0.0:5000",
        "--project",
        "${workspaceFolder}/server/CollectorsVault.Api.csproj"
      ],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Now listening on:"
        }
      }
    },
    {
      "label": "Client: Start Dev Server",
      "type": "shell",
      "command": "npm",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}/client",
        "env": {
          "FAST_REFRESH": "false",
          "NODE_OPTIONS": "--openssl-legacy-provider",
          "HOST": "0.0.0.0"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Compiled successfully"
        }
      }
    },
    {
      "label": "Full Stack: API + Client",
      "dependsOn": [
        "API: Run .NET",
        "Client: Start Dev Server"
      ],
      "dependsOrder": "parallel"
    }
  ]
}